# ================================================
# LawSaaS - Environment Variables Template
# انسخ هذا الملف إلى .env وعبئ القيم الحقيقية
# NEVER commit .env to git
# ================================================

# --- قاعدة البيانات ---
# للتطوير المحلي (SQLite)
DATABASE_URL=sqlite:///./law_firm.db

# للإنتاج على Supabase/PostgreSQL (علّق السطر أعلاه وفعّل هذا)
# DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# --- تشفير الجلسات ---
# رمز سري عشوائي طويل — استخدم: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_PYTHON_SECRETS_MODULE

# --- إعدادات التطبيق ---
APP_ENV=development
# القيم المتاحة: development | production
DEBUG=true

# --- إعدادات SMTP (البريد الإلكتروني) ---
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USERNAME=your_email@icloud.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_SENDER=your_email@icloud.com
SMTP_USE_TLS=true

# --- إعدادات الرفع (Uploads) ---
UPLOAD_DIR=static/uploads/documents
MAX_UPLOAD_SIZE_MB=20
